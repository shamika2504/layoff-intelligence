# Copy this file to .env and fill in your values
# NEVER commit the .env file — only commit this .env.example

# AWS credentials (from IAM user you create on Day 1)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 bucket name (you choose this when creating the bucket)
S3_BUCKET_NAME=layoff-intelligence-yourname

# Athena config
ATHENA_DATABASE=layoff_db
ATHENA_OUTPUT_LOCATION=s3://layoff-intelligence-yourname/athena-results/

# OpenAI 
OPENAI_API_KEY=your_openai_key_here

# BLS API key
BLS_API_KEY=your_bls_key_here
